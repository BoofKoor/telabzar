# secrets & local config
.env
.env.*
!.env.example

# python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# data / runtime
data/
*.log

# os / editor
.DS_Store
.idea/
.vscode/

# Cloudflare origin cert material (never commit)
certs/*.pem
certs/*.key

# downloader cookie files (throwaway-account sessions — never commit)
cookies/*.txt
cookies/*

# پوشهٔ کوکی‌ها را نگه‌دار ولی محتوایش را نه
!cookies/.gitkeep
