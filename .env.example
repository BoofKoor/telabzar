# ── تل‌ابزار · نمونهٔ پیکربندی ──────────────────────────────
# این فایل را دستی ویرایش نکن؛ با ./install.sh مقادیر پرسیده می‌شوند.
# (نمونه است؛ فایل واقعی .env توسط installer ساخته می‌شود.)

# Telegram
BOT_TOKEN=123456:ABC-your-bot-token
TG_API_ID=0000000
TG_API_HASH=your_api_hash_from_my.telegram.org
ADMIN_IDS=111111111
DEFAULT_LANG=fa
MAX_FILE_MB=2000

# Webhook (داخلی — local-bot-api آپدیت‌ها را به این آدرس می‌فرستد)
WEBHOOK_SECRET=change-me-random

# Postgres
POSTGRES_USER=telabzar
POSTGRES_PASSWORD=change-me-random
POSTGRES_DB=telabzar

# Delivery / دامنه (اختیاری — فاز بعد)
DOMAIN=
